# ─────────────────────────────────────────────────────────────
# InDeed Backend — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (your Vercel frontend, localhost, etc.)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
# Number of reverse-proxy hops to trust for client IP (Vercel/Render/Fly = 1)
TRUST_PROXY_HOPS=1

# Rate limiting: set REDIS_URL to share counters across instances (recommended in
# production). When empty, an in-memory store is used (per-process only).
REDIS_URL=

# PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql://user:password@host:5432/indeed
# Set to "true" when connecting to Supabase / any managed Postgres that requires SSL
DATABASE_SSL=true
# TLS certificate verification stays ON by default. If your provider uses a
# private CA, supply the PEM bundle here instead of disabling verification:
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Last-resort dev-only escape hatch (disables MITM protection — never set in prod):
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# JSON Web Tokens
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# AWS S3 (image / deed document storage)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
AWS_S3_BUCKET=indeed-properties

# Anthropic Claude (fraud detection)
ANTHROPIC_API_KEY=sk-ant-...
# Optional override; defaults to claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Africa's Talking (OTP SMS)
AFRICA_TALKING_API_KEY=...
AFRICA_TALKING_USERNAME=sandbox
# Optional alphanumeric / short-code sender id
AFRICA_TALKING_SENDER_ID=

# OTP behaviour
OTP_EXPIRY_MINUTES=10
# In development you can echo the OTP back in the API response (NEVER enable in prod)
OTP_DEBUG_RETURN=false

# Idswyft (Zambian NRC identity verification)
IDSWYFT_API_KEY=
IDSWYFT_BASE_URL=https://api.idswyft.com
# Use a deterministic local mock instead of calling the real API.
# Auto-enabled when IDSWYFT_API_KEY is empty, so dev/test never block on it.
IDSWYFT_MOCK=false

# Stripe (card payments). Payment endpoints fail clearly until these are set.
STRIPE_SECRET_KEY=
# From `stripe listen` / the Stripe dashboard — required to verify webhooks.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=zmw
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Satellite imagery (property location verification). Falls back to a local mock
# when SATELLITE_API_KEY is empty, so dev/test never block on imagery.
SATELLITE_API_KEY=
# {lat}/{lng}/{apiKey} are substituted. Default is Google Static Maps satellite;
# point this at a Google Earth Engine thumbnail URL for production.
SATELLITE_IMAGE_URL_TEMPLATE=https://maps.googleapis.com/maps/api/staticmap?center={lat},{lng}&zoom=18&size=640x640&maptype=satellite&key={apiKey}
SATELLITE_MOCK=false
