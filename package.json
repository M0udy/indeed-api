{
  "name": "indeed-backend",
  "version": "1.0.0",
  "description": "InDeed — AI-powered property fraud detection platform backend for Zambia and East Africa",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "keywords": [
    "property",
    "fraud-detection",
    "real-estate",
    "zambia",
    "claude",
    "ai"
  ],
  "author": "InDeed",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "africastalking": "^0.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "json-rules-engine": "^6.6.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.1",
    "pg": "^8.13.1",
    "stripe": "^17.4.0",
    "tesseract.js": "^4.1.1",
    "zod": "^3.24.1"
  },
  "_overrides_note": "jsonpath-plus is forced to a patched release to close an RCE advisory pulled in transitively by json-rules-engine; our rules never use JSONPath path expressions, so this is behaviour-safe.",
  "overrides": {
    "jsonpath-plus": "^10.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.9",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
